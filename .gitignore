# Configuración/registro de doctyp (correlativos, versiones, inicio): estado local, no se versiona.
settings.json

# Daemon de sincronización (doctyp sync/login en segundo plano): pidfile/log, estado local.
sync_daemon.pid
sync_daemon.log

# Salidas de compilación de informes (el manual de referencia sí se versiona)
*.pdf
!TI-MAN-GOB_2026-0020_v2.0_20260514.pdf
__pycache__/

# SPA Vue 3 (Etapa 5): dependencias y build, no se versionan; el código fuente sí.
web/node_modules/
web/dist/

# Plantillas (Etapa 9): documento de muestra y vista previa efímeros, regenerados on-demand
# para la miniatura y el editor de plantillas (nunca tocan el lib.typ real ni se comparten).
organizations/*/templates/*/.*.preview.lib.typ
organizations/*/templates/*/.*.preview.typ
organizations/*/templates/*/.*.preview.pdf
organizations/*/templates/*/.*.muestra.typ
organizations/*/templates/*/*.miniatura.png
doctyp.db
doctyp.db-shm
doctyp.db-wal