#!/usr/bin/env bash
#
# init — Instalador de doctyp (generador de informes Typst · SLEP Chinchorro).
#
# Asegura las dependencias (Python 3, Typst) y crea los symlinks del comando (doctyp + alias
# ty/tp/dt) en ~/.local/bin. Pensado para ejecutarse una sola vez tras clonar el repositorio.
# Soporta Ubuntu, Debian, Fedora/RHEL, Arch, openSUSE y macOS.
# En Windows usa el instalador equivalente init.ps1 (PowerShell).
#
# Nota sobre fuentes: las fuentes oficiales (Museo Sans + gobCL) viven en
# organizations/<org>/templates/<plantilla>/fonts/ y NO se instalan en el sistema — `doctyp
# compile` las pasa a Typst vía --font-path para cada documento, sin tocar fontconfig.
#
# Uso:
#   ./init
#
set -euo pipefail

# Directorio real del repositorio (donde vive este script).
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="$HOME/.local/bin"
ALIASES=(doctyp ty tp dt)

info()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
ok()    { printf '\033[1;32m  ✔\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m  ⚠\033[0m %s\n' "$*"; }
err()   { printf '\033[1;31mERROR:\033[0m %s\n' "$*" >&2; }

# --------------------------------------------------------------------------
# Detección de distribución
# --------------------------------------------------------------------------
detect_distro() {
  if [ -r /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    case "${ID:-}${ID_LIKE:-}" in
      *fedora*|*rhel*|*centos*) echo "fedora" ;;
      *ubuntu*)                 echo "ubuntu" ;;
      *debian*)                 echo "debian" ;;
      *arch*)                   echo "arch" ;;
      *suse*)                   echo "suse" ;;
      *)                        echo "unknown" ;;
    esac
  elif [ "$(uname -s)" = "Darwin" ]; then
    echo "macos"
  else
    echo "unknown"
  fi
}

DISTRO="$(detect_distro)"
info "Distribución detectada: ${DISTRO}"

# Gestor de paquetes según distro.
case "$DISTRO" in
  fedora)         PM_INSTALL="sudo dnf install -y" ;;
  ubuntu|debian)  PM_INSTALL="sudo apt-get install -y"; sudo apt-get update -qq || true ;;
  arch)           PM_INSTALL="sudo pacman -S --noconfirm" ;;
  suse)           PM_INSTALL="sudo zypper install -y" ;;
  macos)          if command -v brew >/dev/null 2>&1; then PM_INSTALL="brew install"; else PM_INSTALL=""; fi ;;
  *)              PM_INSTALL="" ;;
esac

# Instala un paquete del sistema (o avisa si no hay gestor soportado).
pkg_install() {
  local pkg="$1"
  if [ -z "$PM_INSTALL" ]; then
    warn "Distribución no soportada para instalación automática; instala '$pkg' manualmente."
    return 1
  fi
  info "Instalando '$pkg'..."
  # shellcheck disable=SC2086
  $PM_INSTALL "$pkg"
}

# --------------------------------------------------------------------------
# 1) Python 3
# --------------------------------------------------------------------------
info "Comprobando Python 3..."
if command -v python3 >/dev/null 2>&1; then
  ok "Python 3 presente: $(python3 --version 2>&1)"
else
  pkg_install python3 && ok "Python 3 instalado." || err "No se pudo instalar Python 3."
fi

# --------------------------------------------------------------------------
# 2) Typst
# --------------------------------------------------------------------------
info "Comprobando Typst..."
if command -v typst >/dev/null 2>&1; then
  ok "Typst presente: $(typst --version 2>&1)"
else
  case "$DISTRO" in
    fedora)
      pkg_install typst && ok "Typst instalado." || \
        warn "No se pudo instalar Typst con dnf. Alternativa: 'cargo install typst-cli'."
      ;;
    arch)
      pkg_install typst && ok "Typst instalado." || \
        warn "No se pudo instalar Typst con pacman. Alternativa: 'cargo install typst-cli'."
      ;;
    macos)
      pkg_install typst && ok "Typst instalado." || \
        warn "No se pudo instalar Typst con brew. Alternativa: 'cargo install typst-cli'."
      ;;
    ubuntu|debian|suse)
      # Typst no está en los repos estándar de Debian/Ubuntu/SUSE; se intenta snap o cargo.
      if command -v snap >/dev/null 2>&1; then
        info "Instalando Typst vía snap..."
        sudo snap install typst --classic && ok "Typst instalado (snap)." || \
          warn "Falló snap. Instala Typst con 'cargo install typst-cli' o desde GitHub releases."
      else
        warn "Typst no está en los repos de ${DISTRO}. Instálalo con uno de:"
        warn "  sudo snap install typst --classic"
        warn "  cargo install typst-cli"
        warn "  o binario desde https://github.com/typst/typst/releases"
      fi
      ;;
    *)
      warn "Instala Typst manualmente: https://github.com/typst/typst/releases"
      ;;
  esac
fi

# --------------------------------------------------------------------------
# 3) Symlinks del comando (doctyp + alias)
# --------------------------------------------------------------------------
info "Creando symlinks en ${BIN_DIR}..."
chmod +x "$REPO_DIR/doctyp.py"
mkdir -p "$BIN_DIR"
for n in "${ALIASES[@]}"; do
  ln -sf "$REPO_DIR/doctyp.py" "$BIN_DIR/$n"
  ok "$n → $REPO_DIR/doctyp.py"
done

# --------------------------------------------------------------------------
# 4) tinymist (motor de vista previa con clic↔cursor -- Etapa 15/16, ver CLAUDE.md §6)
# --------------------------------------------------------------------------
# Sin tinymist, `doctyp web` degrada automáticamente a la vista previa typst.ts (sin
# clic↔cursor) -- no es un requisito duro, pero sin él se pierde esa funcionalidad. Versión
# pineada a la verificada empíricamente contra el protocolo real (ver MIN_TINYMIST_VERSION en
# doctyp_preview_binary.py -- mantener ambas en sincronía si se actualiza).
TINYMIST_VERSION="0.15.2"
info "Comprobando tinymist..."
if command -v tinymist >/dev/null 2>&1; then
  ok "tinymist presente: $(tinymist -V 2>&1)"
elif ! command -v curl >/dev/null 2>&1; then
  warn "curl no disponible; no se puede instalar tinymist automáticamente."
  warn "Instálalo manualmente: https://github.com/Myriad-Dreamin/tinymist/releases"
else
  info "Instalando tinymist ${TINYMIST_VERSION} en ${BIN_DIR} (binario oficial vía GitHub releases)..."
  # Instalador oficial de tinymist (cargo-dist): detecta plataforma/arquitectura solo.
  # TINYMIST_INSTALL_DIR fuerza layout "flat" (el binario queda directo en $BIN_DIR, sin
  # subcarpeta bin/ propia) -- mismo directorio que los symlinks de arriba, ya en el PATH.
  # TINYMIST_NO_MODIFY_PATH evita que además intente tocar el shell rc (el paso 6 ya lo hace).
  if TINYMIST_INSTALL_DIR="$BIN_DIR" TINYMIST_NO_MODIFY_PATH=1 \
      curl --proto '=https' --tlsv1.2 -LsSf \
      "https://github.com/Myriad-Dreamin/tinymist/releases/download/v${TINYMIST_VERSION}/tinymist-installer.sh" \
      | sh
  then
    ok "tinymist instalado: $("$BIN_DIR/tinymist" -V 2>&1)"
  else
    warn "No se pudo instalar tinymist automáticamente. La vista previa usará el motor"
    warn "typst.ts (sin clic↔cursor). Instálalo manualmente:"
    warn "  https://github.com/Myriad-Dreamin/tinymist/releases"
  fi
fi

# --------------------------------------------------------------------------
# 5) Datos del autor (settings.json -> local.author)
# --------------------------------------------------------------------------
# Se piden interactivamente y se guardan globalmente; al crear documentos, doctyp los usa por
# defecto. Se delega en el propio script (config-author) para tener una única fuente de la lógica.
# Volver a ejecutar `init` permite cambiarlos (en blanco se mantiene el valor actual).
PYTHON="$(command -v python3 || command -v python || true)"
if [ -n "$PYTHON" ] && [ -t 0 ]; then
  info "Configurando datos del autor (se guardan en settings.json)..."
  "$PYTHON" "$REPO_DIR/doctyp.py" config-author || warn "No se pudo configurar el autor."
else
  warn "Omito la configuración del autor (sin Python o sin terminal interactiva)."
  warn "Configúralo luego con:  doctyp config-author"
fi

# --------------------------------------------------------------------------
# 6) PATH
# --------------------------------------------------------------------------
if printf '%s' ":$PATH:" | grep -q ":$BIN_DIR:"; then
  ok "${BIN_DIR} ya está en el PATH."
else
  warn "${BIN_DIR} no está en el PATH. Añádelo a tu shell y reabre la terminal:"
  printf '      \033[1mecho '\''export PATH="$HOME/.local/bin:$PATH"'\'' >> ~/.bashrc\033[0m\n'
fi

# --------------------------------------------------------------------------
# 7) Autoarranque del daemon de sincronización (doctyp-sync)
# --------------------------------------------------------------------------
# 'doctyp sync'/'doctyp login' ya relanzan el daemon solos si detectan que no está vivo -- esta
# sección solo cubre el arranque automático al iniciar sesión/equipo. Igual que con tinymist
# (paso 4): se avisa pero no se aborta la instalación si el sistema no lo soporta.
info "Configurando autoarranque de doctyp-sync..."
DOCTYP_BIN="${BIN_DIR}/doctyp"

if [ "$DISTRO" = "macos" ]; then
  PLIST_PATH="$HOME/Library/LaunchAgents/cl.tinorte.doctyp-sync.plist"
  mkdir -p "$HOME/Library/LaunchAgents" "$HOME/Library/Logs"
  cat > "$PLIST_PATH" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>cl.tinorte.doctyp-sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>${DOCTYP_BIN}</string>
        <string>_sync-daemon</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>${HOME}/Library/Logs/doctyp-sync.log</string>
    <key>StandardErrorPath</key>
    <string>${HOME}/Library/Logs/doctyp-sync.log</string>
</dict>
</plist>
EOF
  if command -v launchctl >/dev/null 2>&1; then
    launchctl unload "$PLIST_PATH" >/dev/null 2>&1 || true
    if launchctl load -w "$PLIST_PATH" >/dev/null 2>&1; then
      ok "doctyp-sync se autoarrancará al iniciar sesión (LaunchAgent)."
    else
      warn "No se pudo cargar el LaunchAgent. Cárgalo manualmente:"
      warn "  launchctl load -w \"$PLIST_PATH\""
    fi
  else
    warn "launchctl no disponible; no se pudo registrar el autoarranque."
  fi
else
  UNIT_DIR="$HOME/.config/systemd/user"
  UNIT_PATH="$UNIT_DIR/doctyp-sync.service"
  mkdir -p "$UNIT_DIR"
  cat > "$UNIT_PATH" <<EOF
[Unit]
Description=doctyp — sincronización en segundo plano
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=${DOCTYP_BIN} _sync-daemon
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
EOF
  if command -v systemctl >/dev/null 2>&1 && systemctl --user daemon-reload >/dev/null 2>&1; then
    if systemctl --user enable --now doctyp-sync.service >/dev/null 2>&1; then
      ok "doctyp-sync se autoarrancará al iniciar sesión (systemd --user)."
    else
      warn "No se pudo habilitar el servicio. Hazlo manualmente:"
      warn "  systemctl --user enable --now doctyp-sync.service"
    fi
  else
    warn "systemd de usuario no disponible (entorno headless/minimal); no se pudo registrar"
    warn "el autoarranque. 'doctyp sync'/'doctyp login' igual arrancan el daemon bajo demanda."
    warn "Unidad ya escrita en: $UNIT_PATH"
  fi
fi

echo
ok "Instalación completada. Prueba:  doctyp list"
